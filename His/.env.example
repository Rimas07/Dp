# Порт приложения
PORT=3000

# MongoDB подключение
# Для Docker используйте: mongodb://mongodb:27017/his
# Для локального запуска: mongodb://localhost:27017/his
DB_CONNECTION_STRING=mongodb://mongodb:27017/his

# Ключ шифрования (ВАЖНО: измените в продакшене!)
ENCRYPTION_KEY=your-very-secure-encryption-key-change-this-in-production

# RabbitMQ подключение
# Для Docker используйте: amqp://admin:admin123@rabbitmq:5672
# Для локального запуска: amqp://admin:admin123@localhost:5672
RABBITMQ_URL=amqp://admin:admin123@rabbitmq:5672
